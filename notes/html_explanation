    <!DOCTYPE html>
<html>
    <head>
        <title>Edit Game</title>
    </head>
    <body>
        <h1>Edit Game</h1>
        <form method="POST" action="/update">
            <input type="hidden" name="game_id" value="{{ game[0] }}">
            <input type="text" name="game" value="{{ game[1] }}">
            <input type="text" name="genre" value="{{ game[2] }}">
            <select name="status">
                <option value="Want" {% if game[3] == "Want" %}selected{% endif %}>Want</option>
                <option value="Playing" {% if game[3] == "Playing" %}selected{% endif %}>Playing</option>
                <option value="Played" {% if game[3] == "Played" %}selected{% endif %}>Played</option>
