-------------------------------------styling game cards-------------------------------------------------------
.game-card {
    background-color: #0f3460;
    border-radius: 8px;
    padding: 14px 16px;
    margin: 8px 0;
    display: flex; #turns the card into a flex container,
    #meaning its direct children line up horizontally in a row by default instead of stacking vertically.
    #all of game-card alignment attributes to div block
    #align-items: center;
    #justify-content: space-between;
    #conceptually
    #             <div class="game-card">
    #             <div class="game-info"> is moved by align-items and justify-content
    #             <div class="card-actions"> is moved by align-items and justify-content
    #             </div>
    align-items: center;
    justify-content: space-between; #controls horizontal alignment of children/ space between first display flex and second
    border-left: 3px solid #e94560;
   }

    .game-card .game-info {
    flex: 1;#stretches to fill all available space
}

------------------------------creating container for genre--------------------------------------------------------------
<p class="game-genre"> # create container using <p>
    {{ game[2] if game[2] else "Unknown genre" }}
    {% if game[4] %} &nbsp;·&nbsp; Rating: {{ game[4] }}/10 {% endif %}
</p>

