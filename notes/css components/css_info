_________________________________________styling card actions-----------------------------------------------------------
.game-card .card-actions {
    display: flex;
    #makes card-actions its own flex container
    #so Edit and Delete buttons line up horizontally
    # instead of stacking vertically
    gap: 6px; # this is the gap between the two action cards, edit and delete
}
---------------------------------------create badge container--------------------------------------------------------
<p class="game-title"> # use <p> block to apply changes directly to these lines of text
    {{ game[1] }}
    {% if game[3] == "Playing" %}
        <span class="badge badge-playing">Playing</span> #badge container and badge-playing created
    {% elif game[3] == "Played" %}
        <span class="badge badge-completed">Played</span> #badge container and badge-completed created
    {% else %}
        <span class="badge badge-backlog">Want</span> #badge container and badge-backlog created
    {% endif %}
</p>
# each if has ability to create badge container along with its status.

-----------------------------------------styling badges-----------------------------------------------------------------
#this block just stylizes the text
.badge {
    display: inline-block; # means text on the same line
    padding: 2px 8px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    margin-left: 6px;
}
# this adds color to text
.badge-playing   { background: rgba(233, 69, 96, 0.2);  color: #ff6b81; }
.badge-completed { background: rgba(29, 158, 117, 0.2); color: #5dcaa5; }
.badge-backlog   { background: rgba(136, 135, 128, 0.2); color: #b4b2a9; }

